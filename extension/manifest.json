{
  "manifest_version": 3,
  "name": "Replicon Autofill",
  "version": "1.0.0",
  "description": "Auto-fills time punches and time distribution in Replicon timesheets.",

  "permissions": ["storage", "activeTab"],

  "host_permissions": [
    "https://*.replicon.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Replicon Autofill",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://*.replicon.com/*/my/timesheet*"],
      "js": [
        "content/modules/detector.js",
        "content/modules/punchFiller.js",
        "content/modules/distributionFiller.js",
        "content/modules/ui.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
